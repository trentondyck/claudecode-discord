{
  "name": "claude-code-discord-controller",
  "version": "1.1.0",
  "description": "Control multiple Claude Code sessions from Discord (mobile-friendly)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.38",
    "better-sqlite3": "11.10.0",
    "discord.js": "14.25.1",
    "dotenv": "17.2.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.19.10",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
